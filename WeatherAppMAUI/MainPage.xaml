<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WeatherAppMAUI.MainPage"
             Title="">

    <Grid Padding="20,40,20,20"
          RowSpacing="20"
          RowDefinitions="Auto,Auto,*">
       
        <!-- Title -->
        <Label Grid.Row="0"
               Text="Weather"
               FontSize="32"
               FontAttributes="Bold"
               HorizontalOptions="Start" />

        <!-- Search row -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="10">
            <Entry Grid.Column="0"
                   Placeholder="Enter city..."
                   PlaceholderColor="{StaticResource AppTextMuted}"
                   TextColor="{StaticResource AppTextPrimary}"
                   BackgroundColor="{StaticResource AppSurface}"
                   Text="" />
            <Button Grid.Column="1"
                    Text="Search"
                    BackgroundColor="{StaticResource AppAccent}"
                    TextColor="{StaticResource AppTextPrimary}"
                    CornerRadius="8" />
        </Grid>

        <!-- Weather card -->
        <ScrollView Grid.Row="2">
            <Border Background="{StaticResource AppSurface}"
                    Stroke="{StaticResource AppDivider}"
                    StrokeThickness="1"
                    Padding="20"
                    VerticalOptions="Start">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">

                    <Label Text="London, GB"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <Image Source="https://openweathermap.org/img/wn/04d@2x.png"
                           HeightRequest="120"
                           WidthRequest="120"
                           HorizontalOptions="Center" />

                    <Label Text="18°"
                           FontSize="64"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <Label Text="Partly cloudy"
                           FontSize="18"
                           TextColor="{StaticResource AppTextSecondary}"
                           HorizontalOptions="Center" />

                    <Label Text="Feels like 17°"
                           FontSize="14"
                           TextColor="{StaticResource AppTextMuted}"
                           HorizontalOptions="Center"
                           Margin="0,0,0,12" />

                    <!-- Stats row -->
                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="8">

                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                            <Label Text="Humidity"
                                   FontSize="12"
                                   TextColor="{StaticResource AppTextMuted}"
                                   HorizontalOptions="Center" />
                            <Label Text="72%"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                            <Label Text="Wind"
                                   FontSize="12"
                                   TextColor="{StaticResource AppTextMuted}"
                                   HorizontalOptions="Center" />
                            <Label Text="3.6 m/s"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                            <Label Text="Pressure"
                                   FontSize="12"
                                   TextColor="{StaticResource AppTextMuted}"
                                   HorizontalOptions="Center" />
                            <Label Text="1012 hPa"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>

                    </Grid>

                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>

</ContentPage>