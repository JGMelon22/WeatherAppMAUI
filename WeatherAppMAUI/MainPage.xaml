<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WeatherAppMAUI.MainPage"
             Title="">

    <Grid Padding="20,40,20,20"
          RowSpacing="20"
          RowDefinitions="Auto,Auto,*">

        <!-- Title -->
        <Label Grid.Row="0"
               Text="Weather"
               FontSize="32"
               FontAttributes="Bold"
               HorizontalOptions="Start" />

        <!-- Search row -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="10">
            <Entry Grid.Column="0"
                   x:Name="CityEntry"
                   Placeholder="Enter city..."
                   PlaceholderColor="{StaticResource AppTextMuted}"
                   TextColor="{StaticResource AppTextPrimary}"
                   BackgroundColor="{StaticResource AppSurface}"
                   Text="" />
            <Button Grid.Column="1"
                    x:Name="SearchButton"
                    Text="Search"
                    Clicked="OnSearchClicked"
                    BackgroundColor="{StaticResource AppAccent}"
                    TextColor="{StaticResource AppTextPrimary}"
                    CornerRadius="8" />
        </Grid>

        <ScrollView Grid.Row="2">
            <Grid>
                <!-- Loading -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="{StaticResource AppAccent}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Start"
                                   Margin="0,40,0,0" />

                <!-- Error -->
                <Label x:Name="ErrorLabel"
                       IsVisible="False"
                       Text=""
                       TextColor="{StaticResource AppError}"
                       FontSize="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Start"
                       HorizontalTextAlignment="Center"
                       Margin="20,40,20,0" />

                <!-- Card -->
                <Border x:Name="WeatherCard"
                        IsVisible="False"
                        Background="{StaticResource AppSurface}"
                        Stroke="{StaticResource AppDivider}"
                        StrokeThickness="1"
                        Padding="20"
                        VerticalOptions="Start">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label x:Name="LocationLabel" Text=""
                               FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />

                        <Image x:Name="WeatherIcon"
                               Source="/"
                               HeightRequest="120" WidthRequest="120"
                               HorizontalOptions="Center" />

                        <Label x:Name="TempLabel" Text=""
                               FontSize="64" FontAttributes="Bold" HorizontalOptions="Center" />

                        <Label x:Name="DescriptionLabel" Text=""
                               FontSize="18" TextColor="{StaticResource AppTextSecondary}"
                               HorizontalOptions="Center" />

                        <Label x:Name="FeelsLikeLabel" Text=""
                               FontSize="14" TextColor="{StaticResource AppTextMuted}"
                               HorizontalOptions="Center" Margin="0,0,0,12" />

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                                <Label Text="Humidity" FontSize="12"
                                       TextColor="{StaticResource AppTextMuted}" HorizontalOptions="Center" />
                                <Label x:Name="HumidityLabel" Text="" FontSize="16"
                                       FontAttributes="Bold" HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                                <Label Text="Wind" FontSize="12"
                                       TextColor="{StaticResource AppTextMuted}" HorizontalOptions="Center" />
                                <Label x:Name="WindLabel" Text="" FontSize="16"
                                       FontAttributes="Bold" HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                                <Label Text="Pressure" FontSize="12"
                                       TextColor="{StaticResource AppTextMuted}" HorizontalOptions="Center" />
                                <Label x:Name="PressureLabel" Text="" FontSize="16"
                                       FontAttributes="Bold" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ScrollView>
    </Grid>

</ContentPage>